{
  "name": "devbridge-autocomplete",
  "version": "1.5.0",
  "description": "Autocomplete provides suggestions while you type into the text field.",
  "homepage": "https://github.com/devbridge/jQuery-Autocomplete",
  "author": "Tomas Kirda (https://twitter.com/tkirda)",
  "main": "dist/jquery.autocomplete.js",
  "types": "./typings/jquery.autocomplete.d.ts",
  "license": "MIT",
  "keywords": [
    "jquery-plugin"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "format": "prettier --write ./src ./test ./scripts/build.mjs",
    "format:check": "prettier --check ./src ./test ./scripts/build.mjs",
    "lint": "eslint ./src ./test ./scripts/build.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/devbridge/jQuery-Autocomplete.git"
  },
  "peerDependencies": {
    "jquery": ">=1.9"
  },
  "devDependencies": {
    "@types/jquery": "^3.5.32",
    "eslint": "^9.30.1",
    "jquery": "^3.7.1",
    "jquery-mockjax": "^2.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.6.2",
    "terser": "^5.47.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.6"
  },
  "prettier": {
    "printWidth": 100,
    "trailingComma": "es5",
    "tabWidth": 4
  },
  "files": [
    "dist/",
    "typings/jquery-autocomplete/*.d.ts",
    "readme.md"
  ]
}
