{
  "name": "devbridge-autocomplete",
  "version": "2.0.3",
  "description": "Autocomplete provides suggestions while you type into the text field.",
  "homepage": "https://github.com/devbridge/jQuery-Autocomplete",
  "author": "Tomas Kirda (https://github.com/tkirda)",
  "main": "dist/jquery.autocomplete.js",
  "module": "dist/jquery.autocomplete.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/jquery.autocomplete.esm.js",
      "require": "./dist/jquery.autocomplete.js"
    }
  },
  "license": "MIT",
  "keywords": [
    "jquery-plugin",
    "jquery",
    "autocomplete",
    "typeahead",
    "suggest",
    "suggestions",
    "combobox",
    "dropdown",
    "input",
    "search",
    "ajax"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "format": "prettier --write ./src ./test ./scripts/build.mjs",
    "format:check": "prettier --check ./src ./test ./scripts/build.mjs",
    "lint": "eslint ./test ./scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devbridge/jQuery-Autocomplete.git"
  },
  "peerDependencies": {
    "jquery": ">=3.0"
  },
  "overrides": {
    "jquery1": "npm:jquery@^3.7.1",
    "jquery2": "npm:jquery@^3.7.1",
    "jquery4": "npm:jquery@^3.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jquery": "^3.5.32",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "jquery": "^3.7.1",
    "jquery-mockjax": "^3.0.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.6"
  },
  "prettier": {
    "printWidth": 100,
    "trailingComma": "es5",
    "tabWidth": 4
  },
  "files": [
    "dist/",
    "readme.md",
    "LICENSE"
  ]
}
